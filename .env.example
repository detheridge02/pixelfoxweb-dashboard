# ============================================
# PixelFoxWeb Dashboard — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# --- NextAuth ---
NEXTAUTH_URL=http://vm-kubuntu.angler-carp.ts.net:3000
NEXTAUTH_SECRET=

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Monday.com ---
# Create at: https://pixelfoxweb.monday.com/apps/manage/tokens
MONDAY_API_TOKEN=
MONDAY_LEADS_BOARD_ID=5094493706
MONDAY_PROMPT_DOC_ID=5094495336

# --- Anthropic ---
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
